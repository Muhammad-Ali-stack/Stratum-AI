# ──────────────────────────────────────────────────────────────────────────────
# Stratum AI — Backend Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# ──────────────────────────────────────────────────────────────────────────────

# ── App ───────────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3001

# ── Security ──────────────────────────────────────────────────────────────────
# Generate: node -e "console.log(require('crypto').randomBytes(48).toString('base64'))"
JWT_SECRET=

# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# Must be exactly 64 hex characters.
ENCRYPTION_KEY=

# ── Salesforce ────────────────────────────────────────────────────────────────
# Setup → App Manager → New Connected App
# Enable OAuth, grant scopes: api, refresh_token, offline_access
SALESFORCE_CLIENT_ID=
SALESFORCE_CLIENT_SECRET=
# Must match exactly what's in your Connected App
SALESFORCE_REDIRECT_URI=http://localhost:3001/api/salesforce/callback

# ── AI Providers ──────────────────────────────────────────────────────────────
# Groq (primary) — https://console.groq.com/keys
GROQ_API_KEY=

# Google Gemini (fallback) — https://aistudio.google.com/app/apikey
GEMINI_API_KEY=

# ── Supabase ──────────────────────────────────────────────────────────────────
# https://supabase.com → Project Settings → API
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ── CORS ──────────────────────────────────────────────────────────────────────
# Frontend origin — dev: http://localhost:5000 | prod: https://your-domain.com
CORS_ORIGIN=http://localhost:5000

# ── Rate Limiting ─────────────────────────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=60

# ── Email / SMTP (Daily Digest) ───────────────────────────────────────────────
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=Stratum AI <noreply@yourdomain.com>
DIGEST_CRON_SCHEDULE=0 8 * * *
