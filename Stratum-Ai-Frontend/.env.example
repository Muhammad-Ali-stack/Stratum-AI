# ══════════════════════════════════════════════════════════════════════════════
# Stratum AI — Environment Variables
# ══════════════════════════════════════════════════════════════════════════════
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control — it contains secrets.
#
# Naming conventions:
#   VITE_*   → exposed to the browser bundle (public, non-secret)
#   All others → server-side only (keep secret)
# ══════════════════════════════════════════════════════════════════════════════


# ─────────────────────────────────────────────────────────────────────────────
# FRONTEND (Vite)
# ─────────────────────────────────────────────────────────────────────────────


VITE_API_URL=http://localhost:3001
VITE_APP_NAME=Stratum AI


# ─────────────────────────────────────────────────────────────────────────────
# BACKEND — Server
# ─────────────────────────────────────────────────────────────────────────────

# Node environment: development | production | test
NODE_ENV=development

# Port the Express/backend server listens on (must match VITE_API_URL above).
PORT=3001

# Secret used to sign session cookies / JWTs.
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
SESSION_SECRET=replace_with_a_long_random_string_at_least_64_chars


# ─────────────────────────────────────────────────────────────────────────────
# BACKEND — Database (PostgreSQL)
# ─────────────────────────────────────────────────────────────────────────────

# Full Postgres connection string.
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL=postgresql://postgres:password@localhost:5432/stratum_ai

# Individual connection params (used if DATABASE_URL is not set).
DB_HOST=localhost
DB_PORT=5432
DB_NAME=stratum_ai
DB_USER=postgres
DB_PASSWORD=password

# Max connections in the pool (default: 10).
DB_POOL_MAX=10


# ─────────────────────────────────────────────────────────────────────────────
# BACKEND — Salesforce OAuth 2.0
# ─────────────────────────────────────────────────────────────────────────────
# Register a Connected App in Salesforce Setup → App Manager.
# Callback URL must match: <VITE_APP_URL>/api/salesforce/callback

# Consumer Key from the Connected App.
SALESFORCE_CLIENT_ID=your_salesforce_consumer_key

# Consumer Secret from the Connected App.
SALESFORCE_CLIENT_SECRET=your_salesforce_consumer_secret

# OAuth callback URL (must be registered in Salesforce).
SALESFORCE_REDIRECT_URI=http://localhost:5000/api/salesforce/callback

# Salesforce login endpoint.
# Production orgs : https://login.salesforce.com
# Sandbox orgs    : https://test.salesforce.com
SALESFORCE_LOGIN_URL=https://login.salesforce.com


# ─────────────────────────────────────────────────────────────────────────────
# BACKEND — HubSpot OAuth
# ─────────────────────────────────────────────────────────────────────────────
# Create a Private App or Public App in HubSpot → Settings → Integrations.

HUBSPOT_CLIENT_ID=your_hubspot_client_id
HUBSPOT_CLIENT_SECRET=your_hubspot_client_secret
HUBSPOT_REDIRECT_URI=http://localhost:5000/api/hubspot/callback

# Space-separated OAuth scopes required by the app.
HUBSPOT_SCOPES=crm.objects.contacts.read crm.objects.deals.read crm.objects.companies.read


# ─────────────────────────────────────────────────────────────────────────────
# BACKEND — ServiceNow
# ─────────────────────────────────────────────────────────────────────────────
# Basic-auth credentials for the ServiceNow REST API.

# Your ServiceNow instance subdomain (e.g. "mycompany" for mycompany.service-now.com).
SERVICENOW_INSTANCE=your_instance_subdomain
SERVICENOW_USERNAME=your_servicenow_username
SERVICENOW_PASSWORD=your_servicenow_password


# ─────────────────────────────────────────────────────────────────────────────
# BACKEND — AI Providers
# ─────────────────────────────────────────────────────────────────────────────

# Groq — fast open-source LLM inference (Llama 3, Mixtral).
# Get key: https://console.groq.com/keys
GROQ_API_KEY=your_groq_api_key

# Default Groq model to use.
# Options: llama3-70b-8192 | llama3-8b-8192 | mixtral-8x7b-32768
GROQ_MODEL=llama3-70b-8192

# Google Gemini — multimodal AI by Google.
# Get key: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key

# Default Gemini model.
# Options: gemini-1.5-pro | gemini-1.5-flash | gemini-pro
GEMINI_MODEL=gemini-1.5-flash

# OpenAI (optional — for GPT-4o / GPT-4 Turbo support).
# Get key: https://platform.openai.com/api-keys
OPENAI_API_KEY=your_openai_api_key

# Default OpenAI model (if OpenAI is enabled).
OPENAI_MODEL=gpt-4o

# Which provider to use by default when a user has no preference set.
# Options: groq | gemini | openai
DEFAULT_AI_PROVIDER=groq

# Max tokens the AI may produce per response.
AI_MAX_TOKENS=2048

# Temperature for AI responses (0.0 = deterministic, 1.0 = creative).
AI_TEMPERATURE=0.3


# ─────────────────────────────────────────────────────────────────────────────
# BACKEND — Authentication & Security
# ─────────────────────────────────────────────────────────────────────────────

# JWT signing secret (can be the same as SESSION_SECRET or a separate value).
JWT_SECRET=replace_with_another_long_random_string

# JWT expiry duration (e.g. 7d, 24h, 60m).
JWT_EXPIRES_IN=7d

# Bcrypt salt rounds for password hashing (higher = slower but more secure).
BCRYPT_ROUNDS=12

# Comma-separated list of allowed CORS origins.
# Development : http://localhost:5000
# Production  : https://your-app.replit.app
CORS_ORIGINS=http://localhost:5000


# ─────────────────────────────────────────────────────────────────────────────
# BACKEND — Email (optional — for password reset, notifications)
# ─────────────────────────────────────────────────────────────────────────────

# SMTP provider settings (works with Gmail, Resend, SendGrid, Mailgun, etc.).
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password

# The "from" address shown in outgoing emails.
EMAIL_FROM=Stratum AI <noreply@your-domain.com>


# ─────────────────────────────────────────────────────────────────────────────
# BACKEND — Rate Limiting
# ─────────────────────────────────────────────────────────────────────────────

# Max requests per window per IP on general API routes.
RATE_LIMIT_MAX=100

# Window duration in milliseconds (default: 15 minutes).
RATE_LIMIT_WINDOW_MS=900000

# Stricter limit for AI chat endpoint (tokens are expensive).
CHAT_RATE_LIMIT_MAX=30
CHAT_RATE_LIMIT_WINDOW_MS=60000


# ─────────────────────────────────────────────────────────────────────────────
# BACKEND — Logging
# ─────────────────────────────────────────────────────────────────────────────

# Log level: error | warn | info | http | debug
LOG_LEVEL=info

# Pretty-print logs in development (true/false).
LOG_PRETTY=true
